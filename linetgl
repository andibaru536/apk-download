<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="theme-color" content="#000000">
    <title>LINETOGEL App</title>
    
    <style>
        /* --- Base & Reset --- */
        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #000;
            background-image: radial-gradient(circle at top right, #1a1a1a, #000000, #000000);
            color: #ffffff;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* --- Header / Top Bar --- */
        .header {
            padding: 40px 20px 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }

        .logo-container {
            position: relative;
            margin-bottom: 15px;
        }

        .avatar {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .brand-title {
            font-size: 18px;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.9);
        }

        /* --- Main Content --- */
        .container {
            padding: 20px;
            padding-bottom: 100px; /* Space for bottom nav */
            max-width: 600px;
            margin: 0 auto;
        }

        /* --- Quick Action Buttons (Login/Daftar) --- */
        .action-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 30px;
        }

        .btn-action {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
            border-radius: 16px;
            text-decoration: none;
            font-weight: 700;
            font-size: 15px;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .btn-action:active {
            transform: scale(0.98);
            opacity: 0.9;
        }

        .btn-login {
            background: #ffffff;
            color: #000000;
        }

        .btn-daftar {
            background: transparent;
            color: #ffffff;
            border: 2px solid rgba(255,255,255,0.2);
        }
        
        .btn-daftar:active {
            border-color: #fff;
        }

        /* --- Menu Grid Layout (Kiri - Kanan) --- */
        .menu-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .menu-card {
            background: rgba(255, 255, 255, 0.03); /* Glass look */
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 20px;
            padding: 25px 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            color: #fff;
            transition: all 0.3s ease;
            min-height: 130px; /* Tinggi seragam */
            position: relative;
            overflow: hidden;
        }

        /* Glow effect saat disentuh */
        .menu-card:active {
            background: rgba(255, 255, 255, 0.08);
            transform: translateY(-2px);
        }

        .menu-icon-bg {
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 12px;
            border-radius: 15px;
            transition: transform 0.3s ease;
        }

        .menu-card:active .menu-icon-bg {
            transform: scale(1.1);
        }

        .menu-icon-bg svg {
            width: 26px;
            height: 26px;
            fill: #fff;
        }

        .menu-title {
            font-size: 13px;
            font-weight: 600;
            text-align: center;
            opacity: 0.9;
        }

        /* Warna Ikon (Subtle) */
        .icon-blue { background: rgba(33, 150, 243, 0.15); box-shadow: 0 4px 15px rgba(33, 150, 243, 0.15); }
        .icon-pink { background: rgba(233, 30, 99, 0.15); box-shadow: 0 4px 15px rgba(233, 30, 99, 0.15); }
        .icon-purple { background: rgba(156, 39, 176, 0.15); box-shadow: 0 4px 15px rgba(156, 39, 176, 0.15); }
        .icon-orange { background: rgba(255, 152, 0, 0.15); box-shadow: 0 4px 15px rgba(255, 152, 0, 0.15); }
        .icon-green { background: rgba(76, 175, 80, 0.15); box-shadow: 0 4px 15px rgba(76, 175, 80, 0.15); }
        .icon-cyan { background: rgba(0, 188, 212, 0.15); box-shadow: 0 4px 15px rgba(0, 188, 212, 0.15); }

        /* --- Floating Bottom Navigation --- */
        .bottom-nav {
            position: fixed;
            bottom: 20px;
            left: 20px;
            right: 20px;
            height: 65px;
            background: rgba(20, 20, 20, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 30px;
            display: flex;
            justify-content: space-around;
            align-items: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border: 1px solid rgba(255,255,255,0.05);
            z-index: 100;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-decoration: none;
            color: rgba(255,255,255,0.4);
            font-size: 10px;
            font-weight: 500;
            padding: 5px;
            transition: all 0.2s;
        }

        .nav-item.active {
            color: #fff;
            transform: translateY(-2px);
        }

        .nav-item svg {
            width: 24px;
            height: 24px;
            fill: currentColor;
            margin-bottom: 2px;
        }

        /* Center Button (Floating) */
        .nav-center {
            width: 56px;
            height: 56px;
            background: linear-gradient(135deg, #fff, #ddd);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: -30px; /* Naik ke atas */
            box-shadow: 0 5px 20px rgba(255,255,255,0.2);
            text-decoration: none;
        }
        
        .nav-center svg {
            fill: #000;
            width: 28px;
            height: 28px;
            margin: 0;
        }

    </style>
</head>
